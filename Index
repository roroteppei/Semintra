const TOTAL = quizData.length;

export default function SemintraQuiz() {
const [current, setCurrent] = useState(0);
const [selected, setSelected] = useState(null);
const [showResult, setShowResult] = useState(false);
const [score, setScore] = useState(0);
const [finished, setFinished] = useState(false);
const [answers, setAnswers] = useState([]);

const q = quizData[current];
const isCorrect = selected === q.answer;

function handleSelect(idx) {
if (showResult) return;
setSelected(idx);
setShowResult(true);
if (idx === q.answer) setScore((s) => s + 1);
setAnswers((a) => […a, { correct: idx === q.answer }]);
}

function handleNext() {
if (current + 1 >= TOTAL) {
setFinished(true);
} else {
setCurrent((c) => c + 1);
setSelected(null);
setShowResult(false);
}
}

function handleReset() {
setCurrent(0);
setSelected(null);
setShowResult(false);
setScore(0);
setFinished(false);
setAnswers([]);
}

const pct = Math.round((score / TOTAL) * 100);

const grade =
pct >= 90
? { label: “優秀”, color: “#00d4a1”, emoji: “🏆” }
: pct >= 70
? { label: “合格”, color: “#4fc3f7”, emoji: “✅” }
: pct >= 50
? { label: “要復習”, color: “#ffb74d”, emoji: “📖” }
: { label: “再学習”, color: “#ef5350”, emoji: “⚠️” };

return (
<div style={styles.root}>
{/* BG decorative blobs */}
<div style={styles.blob1} />
<div style={styles.blob2} />

```
  <div style={styles.card}>
    {!finished ? (
      <>
        {/* Header */}
        <div style={styles.header}>
          <span style={styles.drugLabel}>💊 SEMINTRA</span>
          <span style={styles.progress}>
            {current + 1} / {TOTAL}
          </span>
        </div>

        {/* Progress bar */}
        <div style={styles.barBg}>
          <div
            style={{
              ...styles.barFill,
              width: `${((current + (showResult ? 1 : 0)) / TOTAL) * 100}%`,
            }}
          />
        </div>

        {/* Score dots */}
        <div style={styles.dots}>
          {Array.from({ length: TOTAL }).map((_, i) => (
            <div
              key={i}
              style={{
                ...styles.dot,
                background:
                  i < answers.length
                    ? answers[i].correct
                      ? "#00d4a1"
                      : "#ef5350"
                    : i === current
                    ? "#fff"
                    : "rgba(255,255,255,0.15)",
                transform: i === current ? "scale(1.3)" : "scale(1)",
              }}
            />
          ))}
        </div>

        {/* Question */}
        <div style={styles.questionBox}>
          <p style={styles.qNum}>問題 {q.id}</p>
          <p style={styles.qText}>{q.question}</p>
        </div>

        {/* Options */}
        <div style={styles.options}>
          {q.options.map((opt, idx) => {
            let bg = "rgba(255,255,255,0.05)";
            let border = "1px solid rgba(255,255,255,0.12)";
            let color = "#e0e0e0";
            if (showResult) {
              if (idx === q.answer) {
                bg = "rgba(0,212,161,0.18)";
                border = "1.5px solid #00d4a1";
                color = "#00d4a1";
              } else if (idx === selected && idx !== q.answer) {
                bg = "rgba(239,83,80,0.18)";
                border = "1.5px solid #ef5350";
                color = "#ef5350";
              }
            } else if (selected === idx) {
              bg = "rgba(255,255,255,0.12)";
              border = "1.5px solid #fff";
            }
            return (
              <button
                key={idx}
                style={{
                  ...styles.optBtn,
                  background: bg,
                  border,
                  color,
                  cursor: showResult ? "default" : "pointer",
                }}
                onClick={() => handleSelect(idx)}
              >
                <span style={styles.optLabel}>
                  {["A", "B", "C", "D"][idx]}
                </span>
                <span style={styles.optText}>{opt}</span>
                {showResult && idx === q.answer && (
                  <span style={styles.mark}>✓</span>
                )}
                {showResult && idx === selected && idx !== q.answer && (
                  <span style={{ ...styles.mark, color: "#ef5350" }}>✗</span>
                )}
              </button>
            );
          })}
        </div>

        {/* Explanation */}
        {showResult && (
          <div style={styles.explain}>
            <div style={styles.explainHeader}>
              <span
                style={{
                  color: isCorrect ? "#00d4a1" : "#ef5350",
                  fontWeight: 700,
                  fontSize: "1rem",
                }}
              >
                {isCorrect ? "✅ 正解！" : "❌ 不正解"}
              </span>
            </div>
            <p style={styles.explainText}>{q.explanation}</p>
          </div>
        )}

        {/* Next button */}
        {showResult && (
          <button style={styles.nextBtn} onClick={handleNext}>
            {current + 1 >= TOTAL ? "結果を見る" : "次の問題へ →"}
          </button>
        )}
      </>
    ) : (
      /* Result screen */
      <div style={styles.result}>
        <div style={styles.resultEmoji}>{grade.emoji}</div>
        <p style={styles.resultGrade} data-color={grade.color}>
          {grade.label}
        </p>
        <div style={styles.scoreCircle}>
          <svg viewBox="0 0 120 120" width="140" height="140">
