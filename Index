              stroke="rgba(255,255,255,0.1)"
              strokeWidth="10"
            />
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke={grade.color}
              strokeWidth="10"
              strokeDasharray={`${2 * Math.PI * 50}`}
              strokeDashoffset={`${2 * Math.PI * 50 * (1 - pct / 100)}`}
              strokeLinecap="round"
              transform="rotate(-90 60 60)"
              style={{ transition: "stroke-dashoffset 1s ease" }}
            />
            <text
              x="60"
              y="55"
              textAnchor="middle"
              fill="#fff"
              fontSize="26"
              fontWeight="700"
            >
              {score}/{TOTAL}
            </text>
            <text
              x="60"
              y="75"
              textAnchor="middle"
              fill="rgba(255,255,255,0.6)"
              fontSize="13"
            >
              {pct}%
            </text>
          </svg>
        </div>

        <div style={styles.resultDots}>
          {answers.map((a, i) => (
            <div
              key={i}
              style={{
                ...styles.rDot,
                background: a.correct ? "#00d4a1" : "#ef5350",
              }}
              title={`Q${i + 1}: ${a.correct ? "正解" : "不正解"}`}
            />
          ))}
        </div>

        <p style={styles.resultMsg}>
          {pct >= 90
            ? "完璧です！セミントラの知識はバッチリですね。"
            : pct >= 70
            ? "よく理解できています。あと少しで満点！"
            : pct >= 50
            ? "基本は押さえられています。副作用・用量を再確認しましょう。"
            : "もう一度添付文書を読み直して挑戦しましょう！"}
        </p>

        <button style={styles.retryBtn} onClick={handleReset}>
          🔁 もう一度挑戦する
        </button>
      </div>
    )}
  </div>

  <p style={styles.footer}>
    セミントラ 4 mg/mL 経口液猫 添付文書（2025年3月改訂）より作成
  </p>
</div>
